{
  "name": "Default Dashboard",
  "elements": [
    {
      "id": "masthead-day",
      "label": "Masthead Day",
      "visible": true,
      "type": "text",
      "text": "{day_name}",
      "font": "Sans",
      "style": "Bold",
      "size": 11,
      "x": 20,
      "y": 10,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0
    },
    {
      "id": "masthead-date-bat",
      "label": "Masthead Date",
      "visible": true,
      "type": "text",
      "text": "{date}  {battery}",
      "font": "Sans",
      "style": "Regular",
      "size": 11,
      "x": 590,
      "y": 10,
      "color": "#000000",
      "align": "right",
      "wrap_width": 0
    },
    {
      "id": "clock-space",
      "label": "Clock Reserved",
      "visible": true,
      "type": "clock_space",
      "x": 263,
      "y": 342,
      "width": 320,
      "height": 105
    },
    {
      "id": "clock-text",
      "label": "Clock Text",
      "visible": true,
      "type": "text",
      "text": "{current_time}",
      "font": "Serif",
      "style": "Regular",
      "size": 64,
      "x": 423,
      "y": 342,
      "color": "#000000",
      "align": "center",
      "wrap_width": 0
    },
    {
      "id": "today-header",
      "label": "Today Header",
      "visible": true,
      "type": "text",
      "text": "Yesterday",
      "font": "Sans",
      "style": "Bold",
      "size": 12,
      "x": 20,
      "y": 200,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0
    },
    {
      "id": "events",
      "label": "Events List",
      "visible": true,
      "type": "list",
      "data_source": "events",
      "item_template": "{time}  {title}",
      "font": "Serif",
      "style": "Regular",
      "size": 11,
      "x": 24,
      "y": 220,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0,
      "line_height": 15,
      "max_items": 3,
      "empty_text": "No events today"
    },
    {
      "id": "tasks-header",
      "label": "Tasks Header",
      "visible": true,
      "type": "text",
      "text": "TASKS",
      "font": "Sans",
      "style": "Bold",
      "size": 12,
      "x": 342,
      "y": 270,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0
    },
    {
      "id": "todos",
      "label": "Todos List",
      "visible": true,
      "type": "list",
      "data_source": "todos",
      "item_template": "{mark}  {text}",
      "font": "Serif",
      "style": "Regular",
      "size": 11,
      "x": 24,
      "y": 290,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0,
      "line_height": 15,
      "max_items": 3,
      "empty_text": "No tasks"
    },
    {
      "id": "quote-header",
      "label": "Quote Header",
      "visible": true,
      "type": "text",
      "text": "QUOTE",
      "font": "Sans",
      "style": "Bold",
      "size": 12,
      "x": 20,
      "y": 340,
      "color": "#000000",
      "align": "left",
      "wrap_width": 0
    },
    {
      "id": "quote-text",
      "label": "Quote Text",
      "visible": true,
      "type": "text",
      "text": "{quote_text}",
      "font": "Serif",
      "style": "Italic",
      "size": 11,
      "x": 24,
      "y": 360,
      "color": "#000000",
      "align": "left",
      "wrap_width": 540
    },
    {
      "id": "quote-author",
      "label": "Quote Author",
      "visible": true,
      "type": "text",
      "text": "{quote_author}",
      "font": "Serif",
      "style": "Regular",
      "size": 11,
      "x": 24,
      "y": 380,
      "color": "#505050",
      "align": "left",
      "wrap_width": 0,
      "prefix": "— "
    },
    {
      "id": "footer",
      "label": "Footer",
      "visible": true,
      "type": "text",
      "text": "Refresh every 60s  |  {updated_at}",
      "font": "Sans",
      "style": "Regular",
      "size": 9,
      "x": 300,
      "y": 780,
      "color": "#787878",
      "align": "center",
      "wrap_width": 0
    }
  ]
}